{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node", "electron"],
    "outDir": "out/main",
    "rootDir": "src"
  },
  "include": ["src/main/**/*", "src/shared/**/*"]
}
